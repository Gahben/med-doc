# MedDoc — Variáveis de ambiente
# Copie este arquivo para .env e preencha com suas credenciais.
# NUNCA commit o arquivo .env — ele já está no .gitignore.

# ── Supabase ─────────────────────────────────────────────────
# Obtenha em: https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ── Cloudflare R2 (opcional — se migrar o storage do Supabase) ─
# Obtenha em: https://dash.cloudflare.com → R2 → Manage API Tokens
# VITE_R2_ACCESS_KEY=
# VITE_R2_SECRET_KEY=
# VITE_CF_ACCOUNT_ID=
